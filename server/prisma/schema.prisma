generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Transaction {
  id       String   @id @default(uuid())
  title    String
  amount   Float
  date     DateTime @default(now())
  category String
  type     String

  @@index([date])
  @@index([category])
}

model Subscription {
  id               String   @id @default(uuid())
  name             String
  price            Float
  billingCycle     String
  nextRenewal      DateTime
  category         String
  remindersEnabled Boolean
}
